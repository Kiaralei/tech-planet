<article class="article-page">
  <header class="article-header">
    <div class="article-meta">
      <time datetime="<%= date_xml(page.date) %>"><%= date(page.date, 'YYYY.MM.DD') %></time>
      <% if (page.categories && page.categories.length) { %>
        <span><%= page.categories.map(function(cat) { return cat.name; }).join(' / ') %></span>
      <% } %>
    </div>
    <h1><%= page.title %></h1>
    <% if (page.tags && page.tags.length) { %>
      <div class="tag-row">
        <% page.tags.toArray().forEach(function(tag) { %>
          <a href="<%- url_for(tag.path) %>"><%= tag.name %></a>
        <% }) %>
      </div>
    <% } %>
  </header>

  <div class="article-grid">
    <aside class="article-side">
      <div class="side-card">
        <span>Filed under</span>
        <strong><%= page.categories && page.categories.length ? page.categories.map(function(cat) { return cat.name; }).join(' / ') : 'Notes' %></strong>
      </div>
      <a class="side-link" href="<%- url_for('/columns/') %>">返回专栏</a>
    </aside>
    <div class="article-content">
      <%- page.content %>
    </div>
  </div>
</article>
